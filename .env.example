NODE_ENV=development
PORT=5000

# Option A: point at MongoDB (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/webharvest

# Option B: no database yet — uncomment so the API still starts (scraping works; auth needs Option A later)
# SKIP_DB=1

JWT_ACCESS_SECRET=replace_me_access
JWT_REFRESH_SECRET=replace_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Set to your frontend origin (React/Next/etc)
CORS_ORIGIN=http://localhost:3000

# In production behind HTTPS, set COOKIE_SECURE=true
COOKIE_SECURE=false
